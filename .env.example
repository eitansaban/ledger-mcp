# ── Ledger project (threads + agent_health tables) ──────────────────────────
LEDGER_SUPABASE_URL=https://YOUR-LEDGER-PROJECT.supabase.co
LEDGER_SUPABASE_SERVICE_KEY=your-ledger-service-role-key

# ── Spend project (spend_log table) ─────────────────────────────────────────
# Can be the same project as the ledger — just reuse the same URL/key.
SPEND_SUPABASE_URL=https://YOUR-SPEND-PROJECT.supabase.co
SPEND_SUPABASE_SERVICE_KEY=your-spend-service-role-key

# ── Access secret ───────────────────────────────────────────────────────────
# Long random string. Required on every request as ?key=... or
# Authorization: Bearer <secret>. Generate with: openssl rand -hex 24
MCP_SECRET=change-me-to-a-long-random-string

# ── Optional ────────────────────────────────────────────────────────────────
# Weekly spend budget in USD (default 10).
# WEEKLY_BUDGET_USD=10
# Per-agent staleness budgets, JSON: {"agent-name": hoursOfSilenceBeforeStale}
# SILENCE_BUDGETS_JSON={"daily-job":30,"weekly-job":192}
